# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_CHAT_PROVIDER=openai_compatible
# LLM_CHAT_API_KEY=sk-xxx
# LLM_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_CHAT_MODEL=qwen-plus
# LLM_CLASSIFY_PROVIDER=openai_compatible
# LLM_CLASSIFY_API_KEY=sk-xxx
# LLM_CLASSIFY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_CLASSIFY_MODEL=qwen-turbo

# Rerank
RERANK_SERVICE_URL=http://rerank-service:8003

# Agent
MAX_ITERATIONS=5
MEMORY_LIMIT=10
