# PostgreSQL (vector search)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=training
POSTGRES_PASSWORD=xxx
POSTGRES_DB=training_agent

# MySQL (user registration, document metadata)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=training
MYSQL_PASSWORD=xxx
MYSQL_DB=training_agent

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=xxx
MINIO_SECRET_KEY=xxx
MINIO_BUCKET=training-docs

# SSO
SSO_CLIENT_ID=xxx
SSO_CLIENT_SECRET=xxx
SSO_REDIRECT_URI=xxx

# Feishu/Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# HR API
HR_API_URL=http://hr-api:8080
HR_API_KEY=xxx

# JWT
JWT_SECRET=xxx
JWT_EXPIRE_MINUTES=1440

# Vector Service
VECTOR_SERVICE_URL=http://vector-service:8001

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_CLASSIFY_TIMEOUT=30
LLM_CHAT_MODEL=
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=
LLM_CHAT_API_HEADER_NAME=
LLM_CHAT_API_HEADER_PREFIX=Bearer 

# Rerank
RERANK_SERVICE_URL=http://rerank-service:8003

# Agent
MAX_ITERATIONS=5
MEMORY_LIMIT=10
