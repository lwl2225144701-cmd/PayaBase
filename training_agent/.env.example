# PostgreSQL (vector search)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=training
POSTGRES_PASSWORD=xxx
POSTGRES_DB=training_agent

# MySQL (user registration, document metadata)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=training
MYSQL_PASSWORD=xxx
MYSQL_DB=training_agent

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=xxx
MINIO_SECRET_KEY=xxx
MINIO_BUCKET=training-docs

# SSO
SSO_CLIENT_ID=xxx
SSO_CLIENT_SECRET=xxx
SSO_REDIRECT_URI=xxx

# Feishu/Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# HR API
HR_API_URL=http://hr-api:8080
HR_API_KEY=xxx

# JWT
JWT_SECRET=xxx
JWT_EXPIRE_MINUTES=1440

# Vector Service
VECTOR_SERVICE_URL=http://vector-service:8001

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ====== LLM 模型(配置化生成模型) ======
# 三类用途各自独立:default / classify / chat / vision
# 切换模型时不需要改任何业务代码,只改下面这些环境变量
# 切换本地/云端模型:只改 provider / base_url / model / api_key 四个字段

# --- 默认(回退配置)---
LLM_PROVIDER=openai
LLM_API_KEY=xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_DEFAULT_TIMEOUT=30

# --- 分类/路由模型(轻量,建议本地)---
# 留空 = 跟随 LLM_*
LLM_CLASSIFY_PROVIDER=
LLM_CLASSIFY_API_KEY=
LLM_CLASSIFY_BASE_URL=
LLM_CLASSIFY_MODEL=
LLM_CLASSIFY_TIMEOUT=30

# --- 聊天生成模型(高质量)---
# 留空 = 跟随 LLM_*
LLM_CHAT_PROVIDER=
LLM_CHAT_API_KEY=
LLM_CHAT_BASE_URL=
LLM_CHAT_MODEL=
LLM_CHAT_TIMEOUT=90
# LLM_CHAT_API_HEADER_NAME=
# LLM_CHAT_API_HEADER_PREFIX=Bearer
#   注意:Bearer 会自动规范化为 "Bearer "(补空格),避免拼成 Bearersk-xxx。
#   其他自定义前缀按原值保留;空值表示不拼接任何前缀。

# --- 视觉模型(图片解析)---
# LLM_VISION_MODEL 必须显式配置,不会自动复用 LLM_MODEL
# (避免普通文本模型被误用于图片识别)
# api_key / base_url / provider 可以留空跟随 LLM_*
# 暂时不需要图片识别可以留空,系统会跳过图片识别或给出清晰错误
#
# 注意:当前实现仅支持 OpenAI-compatible Vision API (如 gpt-4o / qwen-vl-plus)
# provider=ollama 暂不支持图片识别
# 如需本地视觉模型,请提供 OpenAI-compatible 服务入口,或后续新增 Ollama Vision Adapter
LLM_VISION_PROVIDER=
LLM_VISION_API_KEY=
LLM_VISION_BASE_URL=
LLM_VISION_MODEL=
LLM_VISION_TIMEOUT=90

# ============== 配置示例(选其一复制到下方) ==============
# 场景 A:云端生成 + 本地分类(推荐)
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
